#!/bin/bash

# Colyn - Git Worktree 管理工具
# 纯 Node.js 入口（不做目录切换）
# 如需目录切换功能，请 source shell/colyn.sh

# 保存用户当前工作目录
USER_CWD="$(pwd)"

# 定位脚本所在目录（解析软链接，兼容 bash 3.2 / macOS）
# 安装环境下本文件可能通过软链接（targetDir/colyn → colyn.d/bin/colyn）被调用，
# 需先 resolve 软链接，否则 SCRIPT_DIR 会指向软链接所在目录而非真身位置。
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
COLYN_CORE="${PROJECT_DIR}/dist/index.js"

# 检查 Node.js 核心是否存在
if [[ ! -f "${COLYN_CORE}" ]]; then
  echo "错误: 找不到 colyn 核心文件" >&2
  exit 1
fi

# 切换到项目目录
cd "$PROJECT_DIR" || exit 1

# 执行 Node.js 核心
COLYN_USER_CWD="$USER_CWD" node "${COLYN_CORE}" "$@"
